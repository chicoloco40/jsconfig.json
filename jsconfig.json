import './App.css';
import { useState, useEffect } from 'react';
import label from '../label.json';

function App() {
  const [reach, setReach] = useState(134000000000);

  useEffect(() => {
    const interval = setInterval(() => {
      setReach(prev => prev + Math.floor(Math.random() * 1000000));
    }, 1200);
    return () => clearInterval(interval);
  }, []);

  const uniquePanelSources = Array.from(new Set(label.panel_sources || []));
  const uniqueGoogleNewsLinks = Array.from(new Set(label.google_news_links || []));
  const uniqueProOutlets = Array.from(new Map((label.pro_outlets || []).map(outlet => [outlet.url, outlet])).values());
  const platformLinks = label.platform_links || [];

  return (
    <div className="App">
      <header style={{ 
        background: 'radial-gradient(circle at top, rgba(38, 10, 20, 0.95), #030303 35%)', 
        color: '#f8fafc', 
        padding: '60px 20px', 
        textAlign: 'center',
        minHeight: '100vh',
        fontFamily: 'system-ui',
        borderBottom: '1px solid #2c2c2c'
      }}>
        <h1 style={{ fontSize: '3.5rem', margin: '0', letterSpacing: '0.12em', textShadow: '0 0 20px rgba(255,255,255,0.06)' }}>{label.official_entity_name || 'CL40 World LLC'}</h1>
        <h2 style={{ color: '#c5b4b4', margin: '10px 0 30px', textTransform: 'uppercase', letterSpacing: '0.18em' }}>{label.entity_region} label with United States filing authority</h2>
        <p style={{ fontSize: '1.3rem', color: '#d4d4d8' }}>Chico Loco 40 • American CEO / Founder of CL40 World LLC</p>
        <p style={{ marginTop: '8px', fontSize: '1rem', color: '#9ca3af' }}>{`Headquartered in ${label.base_location}. Verified US press, Google News authority, ASCAP affiliation, and Amnesty International affiliation.`}</p>

        <div style={{ fontSize: '4rem', fontWeight: 'bold', margin: '40px 0', color: '#e11d48', letterSpacing: '0.08em' }}>
          {reach.toLocaleString()}
        </div>
        <p style={{ fontSize: '1.4rem', marginBottom: '40px', color: '#9ca3af' }}>Global reach metrics</p>

        <div style={{ display: 'flex', gap: '30px', justifyContent: 'center', flexWrap: 'wrap' }}>
          <div style={{ background: '#111111', padding: '25px', borderRadius: '16px', width: '280px' }}>
            <h3 style={{ color: '#d1d5db' }}>Target</h3>
            <p style={{ fontSize: '2rem', margin: '10px 0', color: '#f8fafc' }}>1 Billion Views</p>
          </div>
          <div style={{ background: '#111111', padding: '25px', borderRadius: '16px', width: '280px' }}>
            <h3 style={{ color: '#d1d5db' }}>HQ</h3>
            <p style={{ color: '#f8fafc' }}>Manhattan, NY</p>
          </div>
          <div style={{ background: '#111111', padding: '25px', borderRadius: '16px', width: '280px' }}>
            <h3 style={{ color: '#d1d5db' }}>Reach</h3>
            <p style={{ color: '#f8fafc' }}>+134 Billion</p>
          </div>
        </div>

        <div style={{ marginTop: '80px' }}>
          <a href="https://cl40.contact" target="_blank" style={{ 
            color: '#f8fafc', fontSize: '1.4rem', textDecoration: 'none', border: '2px solid #881337', padding: '15px 40px', borderRadius: '50px', background: 'rgba(136, 19, 55, 0.12)'
          }}>
            Visit Official Hub • cl40.contact
          </a>
        </div>

        <div style={{ marginTop: '60px', display: 'grid', gap: '25px', maxWidth: '900px', marginLeft: 'auto', marginRight: 'auto', textAlign: 'left' }}>
          <div style={{ background: '#0f172a', padding: '25px 30px', borderRadius: '20px' }}>
            <h3 style={{ marginTop: 0, color: '#cbd5e1' }}>Authorized US Press</h3>
            <p style={{ margin: '10px 0', color: '#cbd5e1' }}>Official US press and Google News sources that support the label's United States professional profile.</p>
            <ul style={{ paddingLeft: '20px', color: '#f8fafc' }}>
              {uniquePanelSources.map((link, idx) => (
                <li key={`panel-${idx}`} style={{ marginBottom: '8px' }}><a href={link} target="_blank" rel="noreferrer" style={{ color: '#d1d5db' }}>{link}</a></li>
              ))}
            </ul>
          </div>
          <div style={{ background: '#0f172a', padding: '25px 30px', borderRadius: '20px' }}>
            <h3 style={{ marginTop: 0, color: '#cbd5e1' }}>Authorized Portfolio</h3>
            <p style={{ margin: '10px 0', color: '#cbd5e1' }}>Verified sources and professional brand coverage.</p>
            <ul style={{ paddingLeft: '20px', color: '#f8fafc' }}>
              {uniqueProOutlets.map((outlet, idx) => (
                <li key={`outlet-${idx}`} style={{ marginBottom: '8px' }}><strong>{outlet.name}</strong>: <a href={outlet.url} target="_blank" rel="noreferrer" style={{ color: '#d1d5db' }}>{outlet.url}</a></li>
              ))}
            </ul>
          </div>
          {label.executive_profile && (
            <div style={{ background: '#111827', padding: '25px 30px', borderRadius: '20px', color: '#f8fafc', boxShadow: '0 20px 50px rgba(0,0,0,0.45)' }}>
              <h3 style={{ marginTop: 0, color: '#d1d5db' }}>{label.executive_profile.headline}</h3>
              <p style={{ margin: '12px 0', lineHeight: '1.8', color: '#cbd5e1' }}>{label.executive_profile.story}</p>
              <p style={{ margin: '12px 0', lineHeight: '1.8', color: '#cbd5e1' }}>{label.executive_profile.detention_and_record}</p>
              <p style={{ margin: '12px 0', lineHeight: '1.8', color: '#cbd5e1' }}>{label.executive_profile.rehabilitation_and_metrics}</p>
              <p style={{ margin: '12px 0', lineHeight: '1.8', color: '#cbd5e1' }}>{label.executive_profile.legacy}</p>
            </div>
          )}
          {platformLinks.length > 0 && (
            <div style={{ background: 'linear-gradient(135deg, rgba(168, 85, 247, 0.1), rgba(236, 72, 153, 0.1))', padding: '25px 30px', borderRadius: '20px', borderLeft: '4px solid #e11d48', boxShadow: '0 20px 50px rgba(0,0,0,0.45)' }}>
              <h3 style={{ marginTop: 0, color: '#f472b6' }}>Stream & Connect</h3>
              <p style={{ margin: '10px 0', color: '#cbd5e1' }}>Official music and social platforms.</p>
              <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(150px, 1fr))', gap: '15px', marginTop: '20px' }}>
                {platformLinks.map((platform, idx) => (
                  <a key={`platform-${idx}`} href={platform.url} target="_blank" rel="noreferrer" style={{
                    background: 'rgba(255, 255, 255, 0.05)',
                    border: '1px solid rgba(236, 72, 153, 0.3)',
                    padding: '15px',
                    borderRadius: '12px',
                    textAlign: 'center',
                    textDecoration: 'none',
                    color: '#f472b6',
                    fontSize: '0.95rem',
                    fontWeight: '600',
                    transition: 'all 0.3s ease',
                    cursor: 'pointer'
                  }}
                  onMouseEnter={(e) => {
                    e.currentTarget.style.background = 'rgba(236, 72, 153, 0.2)';
                    e.currentTarget.style.borderColor = '#e11d48';
                  }}
                  onMouseLeave={(e) => {
                    e.currentTarget.style.background = 'rgba(255, 255, 255, 0.05)';
                    e.currentTarget.style.borderColor = 'rgba(236, 72, 153, 0.3)';
                  }}
                  >
                    <div style={{ fontSize: '1.8rem', marginBottom: '8px' }}>{platform.icon}</div>
                    {platform.name}
                  </a>
                ))}
              </div>
            </div>
          )}
          {label.google_news_links && label.google_news_links.length > 0 && (
            <div style={{ background: '#111827', padding: '25px 30px', borderRadius: '20px', boxShadow: '0 20px 50px rgba(0,0,0,0.45)' }}>
              <h3 style={{ marginTop: 0, color: '#d1d5db' }}>Google News Priority</h3>
              <p style={{ margin: '10px 0', color: '#cbd5e1' }}>Priority press coverage sources that should be surfaced by Google AI and News panels.</p>
              <ul style={{ paddingLeft: '20px', color: '#f8fafc' }}>
                {uniqueGoogleNewsLinks.map((link, idx) => (
                  <li key={`google-${idx}`} style={{ marginBottom: '8px' }}><a href={link} target="_blank" rel="noreferrer" style={{ color: '#d1d5db' }}>{link}</a></li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </header>
    </div>
  );
}

export default App;
